# Flask secret key — set a long random string in production
SECRET_KEY=change-me

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Path where settings.json is stored
# Mount a Railway Volume at this path for persistent config
CONFIG_PATH=/data

# App host/port (Railway injects PORT automatically; WEB_PORT is a fallback)
WEB_HOST=0.0.0.0
WEB_PORT=7070
